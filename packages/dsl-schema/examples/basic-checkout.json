{
  "schemaVersion": "1.0.0",
  "app": {
    "id": "self-checkout-demo",
    "name": "Self Checkout Demo"
  },
  "theme": {
    "bootstrapTheme": "default",
    "primaryColor": "#0d6efd",
    "borderRadius": "md"
  },
  "screens": [
    {
      "id": "home",
      "title": "Home",
      "layout": {
        "type": "row",
        "children": [
          {
            "type": "column",
            "span": {
              "xs": 12,
              "md": 8
            },
            "children": [
              {
                "type": "card",
                "id": "welcome-card",
                "props": {
                  "title": "Welcome",
                  "body": "Type your name below. The value is stored in runtime state and rendered from compiled bindings."
                }
              },
              {
                "type": "input",
                "id": "customer-name-input",
                "props": {
                  "label": "Customer name",
                  "placeholder": "Type your name",
                  "stateKey": "customerName"
                }
              },
              {
                "type": "text",
                "id": "customer-name-preview",
                "props": {
                  "text": ""
                },
                "bindings": {
                  "text": "state.customerName"
                }
              },
              {
                "type": "button",
                "id": "start-button",
                "props": {
                  "label": "Start Checkout",
                  "variant": "primary",
                  "size": "lg"
                },
                "events": {
                  "onClick": [
                    {
                      "type": "navigate",
                      "target": "basket"
                    }
                  ]
                }
              }
            ]
          },
          {
            "type": "column",
            "span": {
              "xs": 12,
              "md": 4
            },
            "children": [
              {
                "type": "card",
                "id": "side-card",
                "props": {
                  "title": "Live state",
                  "body": ""
                },
                "bindings": {
                  "body": "state.customerName"
                }
              },
              {
                "type": "list",
                "id": "features-list",
                "props": {
                  "items": [
                    "Schema validation",
                    "IR compilation",
                    "React renderer",
                    "Runtime state bindings"
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "basket",
      "title": "Basket",
      "layout": {
        "type": "row",
        "children": [
          {
            "type": "column",
            "span": {
              "xs": 12
            },
            "children": [
              {
                "type": "text",
                "id": "basket-title",
                "props": {
                  "text": "Basket"
                }
              },
              {
                "type": "text",
                "id": "basket-customer-name",
                "props": {
                  "text": ""
                },
                "bindings": {
                  "text": "state.customerName"
                }
              },
              {
                "type": "card",
                "id": "basket-card",
                "props": {
                  "title": "Basket screen reached",
                  "body": "Navigation is working and state is preserved across screens."
                }
              },
              {
                "type": "button",
                "id": "back-home",
                "props": {
                  "label": "Back to Home",
                  "variant": "secondary"
                },
                "events": {
                  "onClick": [
                    {
                      "type": "navigate",
                      "target": "home"
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ]
}