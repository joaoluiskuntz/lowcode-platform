{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/lowcode/schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "app", "screens"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "app": {
      "$ref": "#/$defs/App"
    },
    "theme": {
      "$ref": "#/$defs/Theme"
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Screen"
      }
    }
  },
  "$defs": {
    "App": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "Theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bootstrapTheme": { "type": "string" },
        "primaryColor": { "type": "string" },
        "borderRadius": {
          "type": "string",
          "enum": ["none", "sm", "md", "lg", "xl"]
        }
      }
    },
    "Screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "layout"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9-_]+$" },
        "title": { "type": "string" },
        "layout": { "$ref": "#/$defs/LayoutNode" }
      }
    },
    "Span": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "xs": { "type": "integer", "minimum": 1, "maximum": 12 },
        "sm": { "type": "integer", "minimum": 1, "maximum": 12 },
        "md": { "type": "integer", "minimum": 1, "maximum": 12 },
        "lg": { "type": "integer", "minimum": 1, "maximum": 12 },
        "xl": { "type": "integer", "minimum": 1, "maximum": 12 }
      }
    },
    "Action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["navigate", "setState", "callService", "showMessage"]
        },
        "target": { "type": "string" },
        "stateKey": { "type": "string" },
        "value": {},
        "service": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "Events": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "onClick": {
          "type": "array",
          "items": { "$ref": "#/$defs/Action" }
        },
        "onChange": {
          "type": "array",
          "items": { "$ref": "#/$defs/Action" }
        }
      }
    },
    "Bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "RowNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "children"],
      "properties": {
        "type": { "const": "row" },
        "id": { "type": "string" },
        "classList": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bindings": { "$ref": "#/$defs/Bindings" },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LayoutNode" }
        }
      }
    },
    "ColumnNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "span", "children"],
      "properties": {
        "type": { "const": "column" },
        "id": { "type": "string" },
        "classList": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bindings": { "$ref": "#/$defs/Bindings" },
        "span": { "$ref": "#/$defs/Span" },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LayoutNode" }
        }
      }
    },
    "ComponentNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "props"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "button", "image", "input", "card", "list"]
        },
        "id": { "type": "string" },
        "classList": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bindings": { "$ref": "#/$defs/Bindings" },
        "props": {
          "type": "object"
        },
        "events": {
          "$ref": "#/$defs/Events"
        }
      }
    },
    "LayoutNode": {
      "oneOf": [
        { "$ref": "#/$defs/RowNode" },
        { "$ref": "#/$defs/ColumnNode" },
        { "$ref": "#/$defs/ComponentNode" }
      ]
    }
  }
}
