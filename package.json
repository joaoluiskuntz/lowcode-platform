{
    "name":  "lowcode-platform",
    "private":  true,
    "version":  "1.0.0",
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "scripts":  {
                    "build":  "npm run build -ws",
                    "test":  "npm run build -ws \u0026\u0026 npm run test -w @lowcode/validator \u0026\u0026 npm run test -w @lowcode/compiler",
                    "typecheck":  "npm run typecheck -ws",
                    "clean":  "powershell -Command \"Get-ChildItem -Path . -Include dist,node_modules -Recurse -Directory | Remove-Item -Recurse -Force\"",
                    "dev:preview":  "node ./scripts/dev-preview.mjs"
                },
    "devDependencies":  {
                            "@types/node":  "^25.5.0",
                            "typescript":  "^5.9.3",
                            "vitest":  "^4.1.0"
                        }
}