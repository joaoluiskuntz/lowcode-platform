                "componentType": "card",
                "events": {},
                "kind": "component",
                "nodeId": "basket-header",
                "props": {
                  "body": "Compiled UI reading runtime state through safe bindings.",
                  "title": "Basket Summary"
                }
              },
              {
                "bindings": {
                  "text": "state.customerName"
                },
                "classList": [],
                "componentType": "text",
                "events": {},
                "kind": "component",
                "nodeId": "customer-name-text",
                "props": {
                  "text": "Unknown customer"
                }
              },
              {
                "bindings": {
