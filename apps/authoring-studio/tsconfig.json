{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "baseUrl": "../../",
    "paths": {
      "@lowcode/ir": ["packages/ir/src"],
      "@lowcode/component-metadata": ["packages/component-metadata/src"]
    }
  },
  "include": ["src", "test", "../web-preview/src/**/*"]
}